// Fichier : prisma/schema.prisma (Version FINALE avec Factures + Photos + Carte)

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// --- MODÈLE AGENCY (Multi-agence) ---
model Agency {
  id            Int      @id @default(autoincrement())
  name          String                      // "Agence Dupont Immobilier"
  slug          String   @unique            // "agence-dupont" (sous-domaine)
  isActive      Boolean  @default(true)
  logoUrl       String?
  primaryColor  String?  @default("#6366f1")
  stripeCustomerId String? @unique
  createdAt     DateTime @default(now())

  // Relations
  users         User[]
  properties    Property[]
  contacts      Contact[]
  tasks         Task[]
  invoices      Invoice[]
  activities    ActivityLog[]
  appointments  Appointment[]
  subscription  Subscription?  @relation("AgencySubscription")
  diffusions    PropertyDiffusion[]
  documents     Document[]

  @@index([slug])
}

// --- MODÈLE USER ---
model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  role        String   @default("EMPLOYEE") // "OWNER" (patron) ou "EMPLOYEE" (employé)
  createdAt   DateTime @default(now())

  // Sécurité
  resetToken        String?
  resetTokenExpiry  DateTime?
  emailVerified     Boolean  @default(false)
  verificationToken String?

  // Stripe & Subscription
  stripeCustomerId     String?   @unique // ID client Stripe
  subscriptionStatus   String?   @default("inactive") // inactive, active, past_due, canceled, trialing
  subscriptionPlan     String?   // starter, pro, premium
  subscriptionEndDate  DateTime? // Date de fin de l'abonnement

  // Multi-agence
  agency    Agency? @relation(fields: [agencyId], references: [id])
  agencyId  Int?

  // Relations
  properties Property[]
  contacts   Contact[]
  tasks      Task[]
  activities ActivityLog[]
  invoices   Invoice[]
  appointments Appointment[]
  pushSubscriptions PushSubscription[]
  subscription Subscription?
  documents  Document[]

  @@index([agencyId])
}

// --- MODÈLE PROPERTY ---
model Property {
  id          Int      @id @default(autoincrement())
  address     String
  city        String?
  postalCode  String?
  price       Int
  area        Int
  rooms       Int
  bedrooms    Int
  description String?

  // 🏠 TYPE DE BIEN
  propertyType String?  // "APARTMENT", "HOUSE", "STUDIO", "LOFT", "LAND", "COMMERCIAL", "PARKING"

  // 🏢 ÉTAGE
  floor       Int?      // Numéro d'étage (0 = RDC)
  totalFloors Int?      // Nombre total d'étages dans l'immeuble

  // 🚗 ÉQUIPEMENTS EXTÉRIEURS
  parking     Int?      @default(0) // Nombre de places de parking
  hasGarage   Boolean?  @default(false) // Présence d'un garage
  hasBalcony  Boolean?  @default(false) // Présence d'un balcon
  balconyArea Float?    // Surface du balcon/terrasse en m²
  hasTerrace  Boolean?  @default(false) // Présence d'une terrasse
  terraceArea Float?    // Surface de la terrasse en m²
  hasGarden   Boolean?  @default(false) // Présence d'un jardin
  gardenArea  Float?    // Surface du jardin en m²
  hasPool     Boolean?  @default(false) // Présence d'une piscine

  // 🏠 ÉQUIPEMENTS INTÉRIEURS
  hasCellar   Boolean?  @default(false) // Présence d'une cave/cellier
  hasElevator Boolean?  @default(false) // Présence d'un ascenseur

  // Nos ajouts précédents (Photos et Carte)
  imageUrl    String?
  imageUrlEnhanced String? // 📸 Photo améliorée par IA
  imageUrlStaged String? // 🛋️ Photo avec home staging virtuel
  stagingStyle String? // Style de staging (moderne, scandinave, etc.)
  latitude    Float?
  longitude   Float?
  views       Int?     @default(0)

  createdAt   DateTime @default(now())

  agent     User @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   Int

  // Multi-agence
  agency    Agency? @relation(fields: [agencyId], references: [id])
  agencyId  Int?

  tasks     Task[]

  // Relation many-to-many avec Contact (propriétaires)
  owners    PropertyOwner[]

  // 📸 Photos multiples du bien
  images    PropertyImage[]

  // 📡 Diffusion sur portails
  diffusions PropertyDiffusion[]

  // 📝 Documents (mandats, baux, etc.)
  documents  Document[]

  @@index([agentId])
  @@index([agencyId])
}

// --- MODÈLE CONTACT ---
model Contact {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String?
  phoneNumber String?
  type        String   // "BUYER" ou "SELLER"
  createdAt   DateTime @default(now())

  // 🎯 CRITÈRES DE RECHERCHE (pour matching automatique)
  budgetMin   Int?     // Budget minimum (€)
  budgetMax   Int?     // Budget maximum (€)
  cityPreferences String? // Villes préférées (séparées par des virgules)
  minBedrooms Int?     // Nombre minimum de chambres
  minArea     Int?     // Surface minimum (m²)

  // 🔔 PRÉFÉRENCES DE NOTIFICATIONS
  notifyByEmail Boolean @default(true)  // Recevoir des alertes par email
  notifyBySMS   Boolean @default(false) // Recevoir des alertes par SMS
  notifyByPush  Boolean @default(false) // Recevoir des notifications push
  fcmToken      String? // Token Firebase pour notifications push

  agent     User @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   Int

  // Multi-agence
  agency    Agency? @relation(fields: [agencyId], references: [id])
  agencyId  Int?

  tasks     Task[]

  // 👇 C'est ici qu'on ajoute la ligne pour les factures
  invoices  Invoice[]

  // Relation many-to-many avec Property (biens possédés)
  properties PropertyOwner[]

  // Notifications envoyées à ce contact
  notifications Notification[]

  @@index([agentId])
  @@index([agencyId])
}

// --- MODÈLE TASK ---
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  dueDate     DateTime?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  agent     User @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   Int

  // Multi-agence
  agency    Agency? @relation(fields: [agencyId], references: [id])
  agencyId  Int?

  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId   Int?

  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyId  Int?

  @@index([agentId])
  @@index([agencyId])
  @@index([contactId])
  @@index([propertyId])
}

// --- NOUVEAU MODÈLE FACTURE (INVOICE) ---
model Invoice {
  id          Int      @id @default(autoincrement())
  ref         String   // Numéro de facture
  amount      Int      // Montant
  description String   // Motif
  status      String   @default("PENDING") // PENDING ou PAID
  createdAt   DateTime @default(now())

  // Liens
  contact     Contact @relation(fields: [contactId], references: [id])
  contactId   Int

  agent       User    @relation(fields: [agentId], references: [id])
  agentId     Int

  // Multi-agence
  agency    Agency? @relation(fields: [agencyId], references: [id])
  agencyId  Int?

  @@index([agencyId])
}

// --- MODÈLE HISTORIQUE D'ACTIVITÉ ---
model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String   // Ex: "CRÉATION_BIEN", "SUPPRESSION_CONTACT"
  description String   // Ex: "A ajouté le bien 10 rue de la Paix"
  createdAt   DateTime @default(now())

  agent       User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId     Int

  // Multi-agence
  agency    Agency? @relation(fields: [agencyId], references: [id])
  agencyId  Int?

  @@index([agentId])
  @@index([agencyId])
}

// --- TABLE DE JONCTION BIEN-CONTACT (Many-to-Many) ---
model PropertyOwner {
  id         Int      @id @default(autoincrement())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId Int

  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId  Int

  type       String   @default("OWNER") // "OWNER" (propriétaire) ou "INTERESTED" (intéressé)
  createdAt  DateTime @default(now())

  @@unique([propertyId, contactId, type]) // Un contact peut être à la fois propriétaire ET intéressé
  @@index([propertyId])
  @@index([contactId])
}

// --- MODÈLE RENDEZ-VOUS (APPOINTMENT) ---
model Appointment {
  id            Int      @id @default(autoincrement())
  clientName    String   // Nom du client
  clientEmail   String   // Email du client
  clientPhone   String?  // Téléphone (optionnel)
  appointmentDate DateTime // Date et heure du RDV
  duration      Int      @default(60) // Durée en minutes (par défaut 1h)
  status        String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  notes         String?  // Notes optionnelles du client
  createdAt     DateTime @default(now())

  // Lien avec l'agent
  agent         User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId       Int

  // Multi-agence
  agency    Agency? @relation(fields: [agencyId], references: [id])
  agencyId  Int?

  @@index([agentId])
  @@index([agencyId])
  @@index([appointmentDate])
}

// --- MODÈLE NOTIFICATIONS (Historique des alertes envoyées) ---
model Notification {
  id          Int      @id @default(autoincrement())
  type        String   // "NEW_PROPERTY_MATCH", "APPOINTMENT_REMINDER", "NEW_LEAD", etc.
  channel     String   // "EMAIL", "SMS", "PUSH"
  recipient   String   // Email ou numéro de téléphone
  subject     String?  // Sujet de l'email
  body        String   // Contenu du message
  status      String   @default("SENT") // "SENT", "FAILED", "PENDING"
  sentAt      DateTime @default(now())

  // Métadonnées optionnelles (JSON stringifié)
  metadata    String?  // Ex: {"propertyId": 123, "matchScore": 85}

  // Lien avec le contact (optionnel)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId   Int?

  @@index([contactId])
  @@index([type])
  @@index([sentAt])
}

// --- MODÈLE IMAGES DES BIENS (Photos multiples) ---
model PropertyImage {
  id          Int      @id @default(autoincrement())
  url         String   // URL de l'image (Supabase, S3, ou base64)
  isPrimary   Boolean  @default(false) // Photo principale affichée en premier
  order       Int      @default(0) // Ordre d'affichage (0 = première)
  caption     String?  // Légende de la photo (ex: "Salon", "Cuisine", "Chambre 1")
  type        String   @default("ORIGINAL") // "ORIGINAL", "ENHANCED", "STAGED"
  createdAt   DateTime @default(now())

  // Lien avec le bien
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId  Int

  @@index([propertyId])
  @@index([isPrimary])
}

// --- MODÈLE VUES DES BIENS (Analytics détaillés) ---
model PropertyView {
  id          Int      @id @default(autoincrement())
  propertyId  Int      // ID du bien consulté
  ipAddress   String?  // Adresse IP du visiteur (anonymisée)
  userAgent   String?  // Navigateur et système d'exploitation
  referrer    String?  // Origine du trafic (Google, Facebook, lien direct, etc.)
  duration    Int?     // Temps passé sur la page (en secondes)
  device      String?  // Type d'appareil (desktop, mobile, tablet)
  country     String?  // Pays du visiteur (optionnel)
  city        String?  // Ville du visiteur (optionnel)
  converted   Boolean  @default(false) // Si le visiteur a demandé un contact
  viewedAt    DateTime @default(now())

  @@index([propertyId])
  @@index([viewedAt])
  @@index([converted])
}

// --- MODÈLE ABONNEMENTS PUSH (Notifications PWA) ---
model PushSubscription {
  id          Int      @id @default(autoincrement())
  endpoint    String   // URL unique de l'abonnement
  p256dh      String   // Clé publique du client
  auth        String   // Clé d'authentification
  createdAt   DateTime @default(now())

  // Lien avec l'agent
  agent       User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId     Int

  @@unique([agentId, endpoint])
  @@index([agentId])
}

// --- MODÈLE SUBSCRIPTION (Abonnements Stripe) ---
model Subscription {
  id                    Int      @id @default(autoincrement())
  stripeSubscriptionId  String   @unique // ID de l'abonnement Stripe
  stripePriceId         String   // ID du prix Stripe
  stripeCustomerId      String   // ID du client Stripe

  status                String   // active, past_due, canceled, trialing, incomplete, incomplete_expired
  planName              String   // starter, pro, premium
  amount                Int      // Montant en centimes
  currency              String   @default("eur")
  interval              String   // month, year

  currentPeriodStart    DateTime // Début de la période actuelle
  currentPeriodEnd      DateTime // Fin de la période actuelle
  cancelAtPeriodEnd     Boolean  @default(false) // Si l'abonnement sera annulé à la fin
  canceledAt            DateTime? // Date d'annulation
  trialEnd              DateTime? // Fin de la période d'essai

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Lien avec l'utilisateur
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                Int      @unique

  // Multi-agence (l'abonnement appartient à l'agence)
  agency                Agency?  @relation("AgencySubscription", fields: [agencyId], references: [id])
  agencyId              Int?     @unique

  @@index([userId])
  @@index([agencyId])
  @@index([status])
  @@index([stripeCustomerId])
}

// --- MODÈLE SUBSCRIPTION PLANS ---
model SubscriptionPlan {
  id                Int      @id @default(autoincrement())
  stripePriceId     String   @unique // ID du prix Stripe
  stripeProductId   String   // ID du produit Stripe

  name              String   // "Starter", "Pro", "Premium"
  slug              String   @unique // "starter", "pro", "premium"
  description       String?  // Description du plan

  amount            Int      // Montant en centimes
  currency          String   @default("eur")
  interval          String   // "month" ou "year"

  features          Json?    // Liste des fonctionnalités (JSON)

  maxProperties     Int?     // Nombre max de biens
  maxContacts       Int?     // Nombre max de contacts
  maxEmployees      Int?     // Nombre max d'employés
  maxDiffusions     Int?     // Nombre max de diffusions actives (null = illimité)
  maxSignatures     Int?     // Nombre max de signatures par mois (null = illimité)

  isActive          Boolean  @default(true) // Si le plan est disponible
  isFeatured        Boolean  @default(false) // Plan mis en avant

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

// --- MODÈLE WEBHOOK EVENTS (Log des événements Stripe) ---
model StripeWebhookEvent {
  id                String   @id @default(cuid())
  stripeEventId     String   @unique // ID de l'événement Stripe
  type              String   // Type d'événement (checkout.session.completed, etc.)

  data              Json     // Données de l'événement (JSON)

  processed         Boolean  @default(false) // Si l'événement a été traité
  processedAt       DateTime? // Quand l'événement a été traité
  error             String?  // Erreur si le traitement a échoué

  createdAt         DateTime @default(now())

  @@index([stripeEventId])
  @@index([type])
  @@index([processed])
  @@index([createdAt])
}

// --- MODÈLE DIFFUSION SUR PORTAILS ---
model PropertyDiffusion {
  id           Int       @id @default(autoincrement())
  portal       String    // "SELOGER", "LEBONCOIN", "BIENICI", "LOGICIMMO", "PAP", "FIGARO"
  status       String    @default("NOT_PUBLISHED") // "NOT_PUBLISHED", "PUBLISHED", "PENDING", "ERROR"
  publishedAt  DateTime?
  expiresAt    DateTime?
  errorMessage String?

  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId   Int
  agency       Agency?   @relation(fields: [agencyId], references: [id])
  agencyId     Int?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([propertyId, portal])
  @@index([agencyId])
  @@index([propertyId])
}

// --- MODÈLE DOCUMENT (Mandats, Baux, Signature électronique) ---
model Document {
  id            Int       @id @default(autoincrement())
  title         String    // "Mandat de vente - 10 rue de la Paix"
  type          String    // "MANDAT_VENTE", "MANDAT_GESTION", "BAIL_HABITATION"
  status        String    @default("DRAFT") // "DRAFT", "SENT", "SIGNED", "EXPIRED"
  signerName    String    // Nom du signataire
  signerEmail   String    // Email du signataire
  signingToken  String    @unique @default(cuid()) // Token unique pour le lien de signature
  signedAt      DateTime?
  signatureData String?   // Base64 de l'image signature
  signerIp      String?   // IP au moment de la signature

  property      Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyId    Int?

  agent         User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId       Int
  agency        Agency?   @relation(fields: [agencyId], references: [id])
  agencyId      Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([agencyId])
  @@index([agentId])
  @@index([signingToken])
}